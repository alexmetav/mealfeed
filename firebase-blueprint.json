{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the MealFeed platform.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "username": { "type": "string", "description": "The user's unique username." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "profileImage": { "type": "string", "description": "URL or base64 of the user's profile image." },
        "subscriptionPlan": { "type": "string", "enum": ["free", "premium", "pro"], "description": "The user's subscription tier." },
        "healthScore": { "type": "number", "description": "The user's overall health score (0-100)." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "The user's role." },
        "gender": { "type": "string", "enum": ["male", "female", "other"], "description": "The user's gender." },
        "bio": { "type": "string", "description": "A short biography of the user." },
        "walletAddress": { "type": "string", "description": "The user's connected Web3 wallet address." },
        "subscriptionExpiresAt": { "type": "string", "format": "date-time", "description": "When the subscription expires." },
        "points": { "type": "number", "description": "Total points earned by the user." },
        "streak": { "type": "number", "description": "Current daily check-in streak." },
        "lastCheckIn": { "type": "string", "format": "date-time", "description": "Timestamp of the last daily check-in." },
        "dailyLikesCount": { "type": "number", "description": "Number of likes given today." },
        "dailyCommentsCount": { "type": "number", "description": "Number of comments given today." },
        "dailyPostsCount": { "type": "number", "description": "Number of posts uploaded today." },
        "lastActionDate": { "type": "string", "description": "The date (YYYY-MM-DD) of the last recorded action to reset daily limits." },
        "failedScanCount": { "type": "number", "description": "Number of consecutive failed food scans." },
        "scanTimeoutUntil": { "type": "string", "format": "date-time", "description": "Timestamp until which the user is timed out for failed scans." },
        "spamTimeoutUntil": { "type": "string", "format": "date-time", "description": "Timestamp until which the user is timed out for spam." },
        "followersCount": { "type": "number" },
        "followingCount": { "type": "number" },
        "postsCount": { "type": "number" },
        "referralsCount": { "type": "number" },
        "isCreator": { "type": "boolean" },
        "referralCode": { "type": "string" },
        "referredBy": { "type": "string" },
        "checkInHistory": { "type": "array", "items": { "type": "string" } },
        "lastUsernameChange": { "type": "string", "format": "date-time" },
        "lastDisplayNameChange": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "username", "profileImage", "subscriptionPlan", "healthScore", "role", "createdAt", "points", "streak", "dailyLikesCount", "dailyCommentsCount", "dailyPostsCount"]
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "description": "Log of user actions for spam detection.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["post", "comment"] },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "type", "timestamp"]
    },
    "Post": {
      "title": "Post",
      "description": "A food post uploaded by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who created the post." },
        "authorName": { "type": "string", "description": "The name of the author." },
        "authorImage": { "type": "string", "description": "The profile image of the author." },
        "imageUrl": { "type": "string", "description": "Base64 encoded image or URL of the food." },
        "foodType": { "type": "string", "description": "The specific food detected (e.g., Pizza)." },
        "category": { "type": "string", "description": "The category of the food (e.g., Fast Food)." },
        "healthRating": { "type": "string", "enum": ["Low", "Medium", "High"], "description": "The health impact of the food." },
        "healthScore": { "type": "number", "description": "Numeric health score of the meal (0-100)." },
        "caption": { "type": "string", "description": "Optional caption provided by the user." },
        "likesCount": { "type": "number", "description": "Number of likes on the post." },
        "commentsCount": { "type": "number", "description": "Number of comments on the post." },
        "calories": { "type": "number" },
        "protein": { "type": "number" },
        "carbs": { "type": "number" },
        "fat": { "type": "number" },
        "authorIsCreator": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "authorName", "imageUrl", "foodType", "category", "healthRating", "healthScore", "likesCount", "commentsCount", "createdAt"]
    },
    "Like": {
      "title": "Like",
      "description": "A like on a post.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "postId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "postId", "createdAt"]
    },
    "SavedPost": {
      "title": "SavedPost",
      "description": "A post saved by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "postId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "postId", "createdAt"]
    },
    "Comment": {
      "title": "Comment",
      "description": "A comment on a post.",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "authorName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "userId", "authorName", "text", "createdAt"]
    },
    "Follow": {
      "title": "Follow",
      "description": "A follow relationship between two users.",
      "type": "object",
      "properties": {
        "followerId": { "type": "string" },
        "followerName": { "type": "string" },
        "followerImage": { "type": "string" },
        "followingId": { "type": "string" },
        "followingName": { "type": "string" },
        "followingImage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["followerId", "followerName", "followingId", "followingName", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user receiving the notification." },
        "actorId": { "type": "string", "description": "The ID of the user who performed the action." },
        "actorName": { "type": "string", "description": "The name of the user who performed the action." },
        "actorImage": { "type": "string", "description": "The profile image of the actor." },
        "type": { "type": "string", "enum": ["like", "comment", "follow", "message", "admin_message"], "description": "The type of notification." },
        "postId": { "type": "string", "description": "The ID of the post, if applicable." },
        "message": { "type": "string", "description": "The content of the admin message." },
        "link": { "type": "string", "description": "Optional link for the notification." },
        "read": { "type": "boolean", "description": "Whether the notification has been read." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "actorId", "actorName", "type", "read", "createdAt"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A direct message conversation between two users.",
      "type": "object",
      "properties": {
        "users": { "type": "array", "items": { "type": "string" }, "description": "The IDs of the users in the chat." },
        "lastMessage": { "type": "string", "description": "The text of the last message sent." },
        "lastMessageTime": { "type": "string", "format": "date-time", "description": "When the last message was sent." },
        "userDetails": { "type": "object", "description": "Cached details of the users in the chat." },
        "status": { "type": "string", "enum": ["pending", "accepted"] },
        "createdBy": { "type": "string" }
      },
      "required": ["users", "lastMessage", "lastMessageTime", "userDetails"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message within a chat.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string", "description": "The ID of the user who sent the message." },
        "text": { "type": "string", "description": "The text of the message." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Stores food posts."
    },
    "/likes/{likeId}": {
      "schema": { "$ref": "#/entities/Like" },
      "description": "Stores post likes."
    },
    "/saved_posts/{saveId}": {
      "schema": { "$ref": "#/entities/SavedPost" },
      "description": "Stores saved posts."
    },
    "/comments/{commentId}": {
      "schema": { "$ref": "#/entities/Comment" },
      "description": "Stores post comments."
    },
    "/follows/{followId}": {
      "schema": { "$ref": "#/entities/Follow" },
      "description": "Stores user follow relationships."
    },
    "/notifications/{notificationId}": {
      "schema": { "$ref": "#/entities/Notification" },
      "description": "Stores user notifications."
    },
    "/activity_logs/{logId}": {
      "schema": { "$ref": "#/entities/ActivityLog" },
      "description": "Stores activity logs for spam detection."
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Stores direct message conversations."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Stores messages within a chat."
    },
    "/usernames/{username}": {
      "schema": {
        "type": "object",
        "properties": {
          "uid": { "type": "string" }
        },
        "required": ["uid"]
      },
      "description": "Stores unique username mappings to UIDs."
    }
  }
}
